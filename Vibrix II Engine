void RefreshLowRiskFlags()
{
   hasLowRiskBuy = hasLowRiskSell = false;
   for(int i = PositionsTotal()-1; i >= 0; i--)
      if(positionInfo.SelectByIndex(i) && positionInfo.Symbol() == _Symbol && positionInfo.Magic() == InpMagicNumber)
      {
         if(positionInfo.PositionType() == POSITION_TYPE_BUY)  hasLowRiskBuy  = true;
         if(positionInfo.PositionType() == POSITION_TYPE_SELL) hasLowRiskSell = true;
      }
}

bool HasPendingOfType(ENUM_ORDER_TYPE type)
{
   for(int i = OrdersTotal()-1; i >= 0; i--)
   {
      if(!orderInfo.SelectByIndex(i)) continue;
      if(orderInfo.Symbol() != _Symbol || orderInfo.Magic() != InpMagicNumber) continue;
      if(orderInfo.OrderType() == type) return true;
   }
   return false;
}

bool GetIndicator(int handle, int buffer, int shift, double &value)
{
   double tmp[1];
   if(CopyBuffer(handle, buffer, shift, 1, tmp) != 1) return false;
   value = tmp[0];
   return true;
}

double TotalProfit()
{
   double sum = 0;
   for(int i = PositionsTotal()-1; i >= 0; i--)
      if(positionInfo.SelectByIndex(i) && positionInfo.Symbol() == _Symbol && positionInfo.Magic() == InpMagicNumber)
         sum += positionInfo.Profit() + positionInfo.Swap() + positionInfo.Commission();
   return sum;
}

void CloseAllPositions(string reason)
{
   for(int i = PositionsTotal()-1; i >= 0; i--)
      if(positionInfo.SelectByIndex(i) && positionInfo.Symbol() == _Symbol && positionInfo.Magic() == InpMagicNumber)
         trade.PositionClose(positionInfo.Ticket());
   for(int i = OrdersTotal()-1; i >= 0; i--)
      if(orderInfo.SelectByIndex(i) && orderInfo.Symbol() == _Symbol && orderInfo.Magic() == InpMagicNumber)
         trade.OrderDelete(orderInfo.Ticket());
   hasLowRiskBuy = hasLowRiskSell = false;
   if(VerboseLogs) PrintFormat("[CLOSE-ALL] reason=%s", reason);
}

double NormalizeLot(double lot)
{
   double minLot = SymbolInfoDouble(_Symbol, SYMBOL_VOLUME_MIN);
   double maxLot = SymbolInfoDouble(_Symbol, SYMBOL_VOLUME_MAX);
   double stepLot = SymbolInfoDouble(_Symbol, SYMBOL_VOLUME_STEP);
   if(stepLot <= 0) stepLot = 0.01;
   lot = MathFloor(lot / stepLot) * stepLot;
   lot = MathMax(minLot, MathMin(maxLot, lot));
   int decimals = (stepLot >= 0.1) ? 2 : 3;
   return NormalizeDouble(lot, decimals);
}

double ComputeLots()
{
   double lot = Lots;
   if(AutoLot > 0)
   {
      double freeMargin = AccountInfoDouble(ACCOUNT_MARGIN_FREE);
      lot = NormalizeDouble((freeMargin * AutoLot) / 10000.0, 2);
   }
   lot = NormalizeLot(lot);
   if(lot <= 0) return 0;
   double marginReq, ask = SymbolInfoDouble(_Symbol, SYMBOL_ASK);
   if(OrderCalcMargin(ORDER_TYPE_BUY, _Symbol, lot, ask, marginReq))
      if(marginReq > AccountInfoDouble(ACCOUNT_MARGIN_FREE)) return 0;
   return lot;
}

double LookbackHigh(int bars)
{
   double hi[];
   if(CopyHigh(_Symbol, TimeFrame, 1, bars, hi) != bars) return 0;
   double v = hi[0];
   for(int i=1; i<bars; i++) if(hi[i] > v) v = hi[i];
   return v;
}
double LookbackLow(int bars)
{
   double lo[];
   if(CopyLow(_Symbol, TimeFrame, 1, bars, lo) != bars) return 0;
   double v = lo[0];
   for(int i=1; i<bars; i++) if(lo[i] < v) v = lo[i];
   return v;
}

//+------------------------------------------------------------------+
double EffectiveMaxSLDistance()
{
   if(UseATR_Distance) return DynamicDistance(ATR_SL_Multiplier);
   return priceMaxStopLoss;
}

double BuyStopLoss(double entry, double lookbackLow)
{
   double maxDist = EffectiveMaxSLDistance();
   double slDistance = entry - lookbackLow;
   if(slDistance <= 0 || slDistance > maxDist) slDistance = maxDist;
   return NormalizeDouble(entry - slDistance, _Digits);
}
double SellStopLoss(double entry, double lookbackHigh)
{
   double maxDist = EffectiveMaxSLDistance();
   double slDistance = lookbackHigh - entry;
   if(slDistance <= 0 || slDistance > maxDist) slDistance = maxDist;
   return NormalizeDouble(entry + slDistance, _Digits);
}

double GetStopsLevel() { return SymbolInfoInteger(_Symbol, SYMBOL_TRADE_STOPS_LEVEL) * _Point; }

void LogOrderResult(string action, bool ok)
{
   if(!VerboseLogs) return;
   if(ok)
      PrintFormat("[ORDER OK] %s ticket=%I64u code=%u", action, trade.ResultOrder(), trade.ResultRetcode());
   else
      PrintFormat("[ORDER FAIL] %s code=%u %s lastErr=%d",
                  action, trade.ResultRetcode(), trade.ResultRetcodeDescription(), GetLastError());
}

bool OpenBuy(double lot, double sl)
{
   double ask = symInfo.Ask();
   double tp = ComputeTakeProfitPrice(ask, true, lot);
   if(tp > 0 && tp <= ask) tp = 0;
   double stopLevel = GetStopsLevel();
   if(stopLevel > 0)
   {
      if(sl > 0 && (ask - sl) < stopLevel) sl = ask - stopLevel;
      if(tp > 0 && (tp - ask) < stopLevel) tp = ask + stopLevel;
   }
   sl = (sl > 0) ? NormalizeDouble(sl, _Digits) : 0;
   tp = (tp > 0) ? NormalizeDouble(tp, _Digits) : 0;
   bool ok = trade.Buy(lot, _Symbol, ask, sl, tp, InpTradeComment);
   LogOrderResult("BUY market", ok);
   return ok;
}

bool OpenSell(double lot, double sl)
{
   double bid = symInfo.Bid();
   double tp = ComputeTakeProfitPrice(bid, false, lot);
   if(tp > 0 && tp >= bid) tp = 0;
   double stopLevel = GetStopsLevel();
   if(stopLevel > 0)
   {
      if(sl > 0 && (sl - bid) < stopLevel) sl = bid + stopLevel;
      if(tp > 0 && (bid - tp) < stopLevel) tp = bid - stopLevel;
   }
   sl = (sl > 0) ? NormalizeDouble(sl, _Digits) : 0;
   tp = (tp > 0) ? NormalizeDouble(tp, _Digits) : 0;
   bool ok = trade.Sell(lot, _Symbol, bid, sl, tp, InpTradeComment);
   LogOrderResult("SELL market", ok);
   return ok;
}

bool PlacePending(ENUM_ORDER_TYPE type, double lot, double price, double sl, double entryForTP)
{
   bool isBuy = (type == ORDER_TYPE_BUY_STOP || type == ORDER_TYPE_BUY_LIMIT);
   double tp = ComputeTakeProfitPrice(entryForTP, isBuy, lot);
   if(tp > 0)
   {
      if(isBuy && tp <= price) tp = 0;
      if(!isBuy && tp >= price) tp = 0;
   }

   double stopLevel = GetStopsLevel();
   double mkt = isBuy ? symInfo.Ask() : symInfo.Bid();
   double dist = MathAbs(price - mkt);
   if(stopLevel > 0 && dist < stopLevel)
   {
      if(VerboseLogs)
         PrintFormat("[PEND SKIP] type=%d price=%.*f mkt=%.*f dist=%.*f < stopLevel=%.*f",
                     type, _Digits, price, _Digits, mkt, _Digits, dist, _Digits, stopLevel);
      return false;
   }

   price = NormalizeDouble(price, _Digits);
   sl = (sl > 0) ? NormalizeDouble(sl, _Digits) : 0;
   tp = (tp > 0) ? NormalizeDouble(tp, _Digits) : 0;

   bool ok = false;
   string label = "";
   switch(type)
   {
      case ORDER_TYPE_BUY_STOP:
         ok = trade.BuyStop(lot, price, _Symbol, sl, tp, ORDER_TIME_GTC, 0, InpTradeComment);
         label = "BUY STOP"; break;
      case ORDER_TYPE_SELL_STOP:
         ok = trade.SellStop(lot, price, _Symbol, sl, tp, ORDER_TIME_GTC, 0, InpTradeComment);
         label = "SELL STOP"; break;
      case ORDER_TYPE_BUY_LIMIT:
         ok = trade.BuyLimit(lot, price, _Symbol, sl, tp, ORDER_TIME_GTC, 0, InpTradeComment);
         label = "BUY LIMIT"; break;
      case ORDER_TYPE_SELL_LIMIT:
         ok = trade.SellLimit(lot, price, _Symbol, sl, tp, ORDER_TIME_GTC, 0, InpTradeComment);
         label = "SELL LIMIT"; break;
      default: return false;
   }
   LogOrderResult(label, ok);
   return ok;
}

//+------------------------------------------------------------------+
//| Filter helpers                                                   |
//+------------------------------------------------------------------+
// Stoch crossover in OB/OS zone:
//   BUY  : %K crossed above %D (curr>D, prev<=D) AND prev %K was in oversold zone
//   SELL : %K crossed below %D (curr<D, prev>=D) AND prev %K was in overbought zone
bool StochFilter(bool wantBuy)
{
   double k_curr, k_prev, d_curr, d_prev;
   if(!GetIndicator(stochHandle, 0, 1, k_curr)) return false;   // %K main
   if(!GetIndicator(stochHandle, 0, 2, k_prev)) return false;
   if(!GetIndicator(stochHandle, 1, 1, d_curr)) return false;   // %D signal
   if(!GetIndicator(stochHandle, 1, 2, d_prev)) return false;

   if(wantBuy)
   {
      bool crossed = (k_prev <= d_prev) && (k_curr > d_curr);
      bool inOS    = (k_prev <= Stoch_Oversold) || (d_prev <= Stoch_Oversold);
      return crossed && inOS;
   }
   else
   {
      bool crossed = (k_prev >= d_prev) && (k_curr < d_curr);
      bool inOB    = (k_prev >= Stoch_Overbought) || (d_prev >= Stoch_Overbought);
      return crossed && inOB;
   }
}

// MACD main vs signal cross (independent confirmation in addition to core MACD condition)
//   BUY  : main was <= signal previously, now main > signal
//   SELL : main was >= signal previously, now main < signal
bool MACDCrossFilter(bool wantBuy)
{
   double main_curr, main_prev, sig_curr, sig_prev;
   if(!GetIndicator(macdHandle, 0, 1, main_curr)) return false;
   if(!GetIndicator(macdHandle, 0, 2, main_prev)) return false;
   if(!GetIndicator(macdHandle, 1, 1, sig_curr))  return false;
   if(!GetIndicator(macdHandle, 1, 2, sig_prev))  return false;

   if(wantBuy)  return (main_prev <= sig_prev) && (main_curr > sig_curr);
   else         return (main_prev >= sig_prev) && (main_curr < sig_curr);
}

// ADX > threshold (no DI direction check - just "is it trending?")
bool ADXFilter()
{
   double adxVal;
   if(!GetIndicator(adxHandle, 0, 1, adxVal)) return false;     // ADX main line
   return adxVal >= ADX_Threshold;
}

// Master gate: all enabled filters must pass
bool ConfirmationFilters(bool wantBuy)
{
   if(UseFilter_Stoch && !StochFilter(wantBuy))
   {
      if(LogBlockedSignals) PrintFormat("[FILTER] %s blocked by Stoch", wantBuy ? "BUY" : "SELL");
      return false;
   }
   if(UseFilter_MACDCross && !MACDCrossFilter(wantBuy))
   {
      if(LogBlockedSignals) PrintFormat("[FILTER] %s blocked by MACDCross", wantBuy ? "BUY" : "SELL");
      return false;
   }
   if(UseFilter_ADX && !ADXFilter())
   {
      if(LogBlockedSignals) PrintFormat("[FILTER] %s blocked by ADX<thr", wantBuy ? "BUY" : "SELL");
      return false;
   }
   return true;
}

//+------------------------------------------------------------------+
//| OnTick                                                           |
//+------------------------------------------------------------------+
void OnTick()
{
   if(!TerminalInfoInteger(TERMINAL_TRADE_ALLOWED)) return;
   if(!symInfo.RefreshRates()) return;

   RefreshLowRiskFlags();
   UpdateLabels();
   UpdateDrawdownState();
   CheckEquityTakeProfit();
   CheckMoneyTPSL();
   BreakevenAndGridHandler();
   TrailingStopHandler();

   if(UseClosedCandle && !IsNewBar()) return;
   if(!InTradingWindow()) return;
   if(drawdownPaused) return;

   double ma_curr, ma_prev3, bb_mid;
   double macd_main_curr, macd_main_prev;
   double rsi_curr;
   if(!GetIndicator(maHandle,   0, 1, ma_curr))         return;
   if(!GetIndicator(maHandle,   0, 3, ma_prev3))        return;
   if(!GetIndicator(bbHandle,   0, 1, bb_mid))          return;
   if(!GetIndicator(macdHandle, 0, 1, macd_main_curr))  return;
   if(!GetIndicator(macdHandle, 0, 2, macd_main_prev))  return;
   if(!GetIndicator(rsiHandle,  0, 1, rsi_curr))        return;

   double rangeHigh = LookbackHigh(LookbackBars);
   double rangeLow  = LookbackLow(LookbackBars);
   if(rangeHigh <= 0 || rangeLow <= 0) return;

   double ask = symInfo.Ask(), bid = symInfo.Bid();
   double lot = ComputeLots();
   if(lot <= 0) return;

   double deltaStopPx  = UseATR_Distance ? DynamicDistance(ATR_DeltaStop_Multiplier)  : priceDeltaStop;
   double deltaLimitPx = UseATR_Distance ? DynamicDistance(ATR_DeltaLimit_Multiplier) : priceDeltaLimit;

   // === Symmetric core signal ===
   // BUY : MA crosses up through BB middle, MACD main rising, RSI not at extremes
   // SELL: MA crosses down through BB middle, MACD main FALLING (mirror of BUY), RSI not at extremes
   bool buyCore  = (ma_curr > bb_mid) && (ma_prev3 < bb_mid) &&
                   (macd_main_curr > macd_main_prev) &&
                   (rsi_curr > 20 && rsi_curr < 80);
   bool sellCore = (ma_curr < bb_mid) && (ma_prev3 > bb_mid) &&
                   (macd_main_curr < macd_main_prev) &&         // <-- FIXED: was checking signal cross on prev bar
                   (rsi_curr > 20 && rsi_curr < 80);

   bool buySignal  = buyCore  && ConfirmationFilters(true);
   bool sellSignal = sellCore && ConfirmationFilters(false);

   if(LogBlockedSignals)
   {
      if(buyCore  && !buySignal)  Print("[FILTER] BUY core fired but a confirmation filter blocked it");
      if(sellCore && !sellSignal) Print("[FILTER] SELL core fired but a confirmation filter blocked it");
   }

   // BUY low risk
   if(BUY_market_lowRisk && !hasLowRiskBuy && buySignal)
   {
      double sl = BuyStopLoss(ask, rangeLow);
      if(OpenBuy(lot, sl)) hasLowRiskBuy = true;
   }
   // BUY market
   if(BUY_market && buySignal)
   {
      double sl = BuyStopLoss(ask, rangeLow);
      OpenBuy(lot, sl);
   }
   // BUY stop
   if(BUY_stop && buySignal)
   {
      if(SkipIfPendingExists && HasPendingOfType(ORDER_TYPE_BUY_STOP))
      { if(VerboseLogs) Print("[PEND SKIP] BUY STOP already exists"); }
      else
      {
         double price = ask + deltaStopPx;
         double sl = BuyStopLoss(price, rangeLow);
         PlacePending(ORDER_TYPE_BUY_STOP, lot, price, sl, price);
      }
   }
   // BUY limit (fade on sellSignal)
   if(BUY_limit && sellSignal)
   {
      if(SkipIfPendingExists && HasPendingOfType(ORDER_TYPE_BUY_LIMIT))
      { if(VerboseLogs) Print("[PEND SKIP] BUY LIMIT already exists"); }
      else
      {
         double price = bid - deltaLimitPx;
         double sl = BuyStopLoss(price, rangeLow);
         PlacePending(ORDER_TYPE_BUY_LIMIT, lot, price, sl, price);
      }
   }

   // SELL low risk
   if(SELL_market_lowRisk && !hasLowRiskSell && sellSignal)
   {
      double sl = SellStopLoss(bid, rangeHigh);
      if(OpenSell(lot, sl)) hasLowRiskSell = true;
   }
   // SELL market
   if(SELL_market && sellSignal)
   {
      double sl = SellStopLoss(bid, rangeHigh);
      OpenSell(lot, sl);
   }
   // SELL stop
   if(SELL_stop && sellSignal)
   {
      if(SkipIfPendingExists && HasPendingOfType(ORDER_TYPE_SELL_STOP))
      { if(VerboseLogs) Print("[PEND SKIP] SELL STOP already exists"); }
      else
      {
         double price = bid - deltaStopPx;
         double sl = SellStopLoss(price, rangeHigh);
         PlacePending(ORDER_TYPE_SELL_STOP, lot, price, sl, price);
      }
   }
   // SELL limit
   if(SELL_limit)
   {
      bool place = sellSignal;
      if(SELL_limit_StrictFilter)
      {
         double priceToLow = ask - rangeLow;
         place = sellSignal &&
                 (priceToLow >= priceMinSL) && (priceToLow <= priceMinSL * 5);
      }
      if(place)
      {
         if(SkipIfPendingExists && HasPendingOfType(ORDER_TYPE_SELL_LIMIT))
         { if(VerboseLogs) Print("[PEND SKIP] SELL LIMIT already exists"); }
         else
         {
            double price = ask + deltaLimitPx;
            double sl = SellStopLoss(price, rangeHigh);
            PlacePending(ORDER_TYPE_SELL_LIMIT, lot, price, sl, price);
         }
      }
   }
}

