#property copyright "MQL5 conversion - BTC defaults"
#property link      ""
#property version   "1.10"
#property strict
#property description "Vibrix Group EA - intraday scalper (M15-H1)."
#property description "Defaults tuned for BTCUSD. Fully backtestable in MT5."

#include <Trade\Trade.mqh>
#include <Trade\SymbolInfo.mqh>
#include <Trade\PositionInfo.mqh>
#include <Trade\OrderInfo.mqh>
